@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(Threads REQUIRED)
if(APPLE AND CMAKE_SYSTEM_NAME STREQUAL "Darwin")
    find_dependency(Carbon CoreFoundation CoreGraphics REQUIRED)
endif()

include(${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake)

set_and_check(@PROJECT_NAME@_INCLUDE_DIRS @PACKAGE_CMAKE_INSTALL_INCLUDEDIR@)
set_and_check(@PROJECT_NAME@_LIBRARY_DIRS @PACKAGE_CMAKE_INSTALL_LIBDIR@)
set(@PROJECT_NAME@_LIBRARIES @PROJECT_NAME@::@PROJECT_NAME@)

set(@PROJECT_NAME@_VERSION @PROJECT_VERSION@)
set(@PROJECT_NAME@_SHARED @HIDTOOL_SHARED@)
set(@PROJECT_NAME@_FOUND TRUE)
set(@PROJECT_NAME@_HAS_KEYBOARD @HIDTOOL_HAS_KEYBOARD@)
set(@PROJECT_NAME@_HAS_MOUSE @HIDTOOL_HAS_MOUSE@)
check_required_components(@PROJECT_NAME@)
